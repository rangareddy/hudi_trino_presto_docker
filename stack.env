# Default environment for build.sh and run_spark_trino_presto_hudi.sh

# Query engines
ENABLE_TRINO=true
ENABLE_PRESTO=true

DOCKER_HUB_USERNAME=apachehuditrino

# Hudi version: Spark bundle name, Trino/Presto build args, Presto bundle JAR name
HUDI_VERSION=0.14.2-SNAPSHOT

# Spark + Hudi (dockerfiles/Dockerfile.spark)
SPARK_VERSION=3.4.4
JAVA_VERSION=11
SCALA_VERSION=2.12
HADOOP_VERSION=3.3.4
AWS_SDK_VERSION=1.12.772

# Hive Metastore (dockerfiles/Dockerfile.hive)
HIVE_VERSION=3.1.3
TARGET_PLATFORM=linux/amd64

# Trino (dockerfiles/Dockerfile.trino)
TRINO_VERSION=449
TRINO_JAVA_VERSION=22

# Presto (dockerfiles/Dockerfile.presto)
PRESTO_VERSION=0.296
PRESTO_JAVA_VERSION=17
